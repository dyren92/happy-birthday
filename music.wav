import numpy as np
import wave

SAMPLE_RATE = 44100

def tone(freq, duration_ms, volume=0.3):
    length = int(SAMPLE_RATE * duration_ms / 1000)
    t = np.linspace(0, duration_ms / 1000, length, False)

    if freq == 0:
        signal = np.zeros(length)
    else:
        signal = volume * np.sin(2 * np.pi * freq * t)

    return signal

def silence(duration_ms):
    return np.zeros(int(SAMPLE_RATE * duration_ms / 1000))

melody = []

melody += [tone(264,250), silence(250)]
melody += [tone(264,250), silence(125)]
melody += [tone(297,1000), silence(125)]
melody += [tone(264,1000), silence(125)]
melody += [tone(352,1000), silence(125)]
melody += [tone(330,2000), silence(250)]

melody += [tone(264,250), silence(250)]
melody += [tone(264,250), silence(125)]
melody += [tone(297,1000), silence(125)]
melody += [tone(264,1000), silence(125)]
melody += [tone(396,1000), silence(125)]
melody += [tone(352,2000), silence(250)]

melody += [tone(264,250), silence(125)]
melody += [tone(264,500), silence(250)]
melody += [tone(440,1000), silence(125)]
melody += [tone(352,1000), silence(125)]
melody += [tone(330,1000), silence(125)]
melody += [tone(297,1000)]
melody += [tone(440,1000), silence(250)]

melody += [tone(466,250), silence(250)]
melody += [tone(466,250), silence(125)]
melody += [tone(440,1000), silence(125)]
melody += [tone(352,1000), silence(125)]
melody += [tone(396,1000), silence(125)]
melody += [tone(352,2000)]

audio = np.concatenate(melody)

# Normalize and convert to 16‑bit PCM
audio_pcm = np.int16(audio / np.max(np.abs(audio)) * 32767)

# ✅✅ CRITICAL FIX: use "wb"
with wave.open("music.wav", "wb") as f:
    f.setnchannels(1)
    f.setsampwidth(2)      # 16‑bit PCM
    f.setframerate(SAMPLE_RATE)
    f.writeframes(audio_pcm.tobytes())

print("✅ Browser‑compatible music.wav created")
