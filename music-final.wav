def tone(freq, duration_ms):
    frames = int(SAMPLE_RATE * duration_ms / 1000)
    data = bytearray()

    for i in range(frames):
        if freq == 0:
            sample = 0
        else:
            sample = int(
                VOLUME * 32767 *
                math.sin(2 * math.pi * freq * (i / SAMPLE_RATE))
            )
            sample = max(-32768, min(32767, sample))

        data.extend(struct.pack('<h', sample))

    return bytes(data)
